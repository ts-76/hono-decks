{
  "name": "hono-decks-monorepo",
  "private": true,
  "workspaces": [
    "packages/*",
    "examples/*",
    "docs"
  ],
  "type": "module",
  "scripts": {
    "build": "bun run --cwd packages/decks build",
    "dev": "bun run --cwd examples/basic dev",
    "dev:minimal": "bun run --cwd examples/minimal dev",
    "dev:honox": "bun run --cwd examples/honox dev",
    "dev:ogp": "bun run --cwd examples/ogp dev",
    "dev:docs": "bun run --cwd docs dev",
    "build:docs": "bun run --cwd docs build",
    "build:ogp": "bun run --cwd examples/ogp build",
    "deploy:docs": "bun run --cwd docs deploy",
    "deploy:minimal": "bun run --cwd examples/minimal deploy:production",
    "deploy:basic": "bun run --cwd examples/basic deploy:production",
    "deploy:honox": "bun run --cwd examples/honox deploy:production",
    "deploy:ogp": "bun run --cwd examples/ogp deploy:production",
    "decks:compile": "bun run --cwd packages/decks decks:compile",
    "smoke:package": "bun run build && node scripts/smoke-package.mjs",
    "smoke:pdf": "bun run --cwd examples/basic smoke:pdf",
    "smoke:viewport": "bun run --cwd examples/basic smoke:viewport",
    "release": "node scripts/verify-release-baseline.mjs && semantic-release",
    "format": "vp fmt",
    "lint": "vp lint",
    "typecheck": "bun run --cwd packages/decks typecheck && bun run --cwd examples/basic typecheck && bun run --cwd examples/minimal typecheck && bun run --cwd examples/honox typecheck && bun run --cwd examples/ogp typecheck && bun run --cwd docs typecheck",
    "test": "bun run --cwd packages/decks test && bun run --cwd examples/basic test && bun run --cwd examples/minimal test && bun run --cwd examples/honox test && bun run --cwd examples/ogp test && bun run --cwd docs test",
    "check": "vp check && bun run typecheck && bun run test && bun run build:ogp && bun run build:docs"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.12",
    "@cloudflare/workers-types": "^5.20260714.1",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/node": "^25.9.2",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "semantic-release": "^25.0.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:",
    "wrangler": "^4.110.0"
  },
  "overrides": {
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "packageManager": "bun@1.3.13",
  "catalog": {
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.4",
    "vitest": "4.1.10",
    "vite-plus": "0.2.4"
  }
}
