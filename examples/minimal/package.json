{
  "name": "@hono-decks/example-minimal",
  "private": true,
  "type": "module",
  "scripts": {
    "decks:compile": "hono-decks compile",
    "dev": "wrangler dev --live-reload",
    "build": "wrangler deploy --dry-run --outdir dist",
    "deploy": "wrangler deploy",
    "typecheck": "bun run decks:compile && tsc --noEmit",
