{
  "name": "@hono-decks/example-minimal",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.13",
  "scripts": {
    "decks:compile": "hono-decks compile",
    "decks:watch": "hono-decks compile --watch",
    "dev": "bun run decks:compile && wrangler dev",
    "build": "bun run decks:compile && wrangler deploy --dry-run --outdir dist",
    "deploy": "bun run decks:compile && wrangler deploy",
    "typecheck": "bun run decks:compile && tsc --noEmit",
    "test": "bun run decks:compile && vitest run",
    "check": "bun run typecheck && bun run test && bun run build"
  },
  "dependencies": {
    "hono-decks": "file:./vendor/hono-decks-0.2.1.tgz",
    "hono": "^4.12.30"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260714.1",
    "@types/node": "^25.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14",
    "wrangler": "^4.50.0"
  }
}
