  },
  "dependencies": {
    "hono": "^4.12.30",
    "hono-decks": "file:./vendor/hono-decks-0.1.0.tgz"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260714.1",
    "@types/node": "^25.9.2",
    "typescript": "^5.9.3",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:",
    "wrangler": "^4.110.0"
  },
  "packageManager": "bun@1.3.13"
}
