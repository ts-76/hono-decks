{
  "name": "@hono-slides/example-basic",
  "private": true,
  "type": "module",
  "scripts": {
    "slides:compile": "bun ../../packages/hono-slides/src/cli.ts compile --root decks --out src/generated/deck-manifest.ts --mount /decks",
    "dev": "bun run slides:compile && wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "bun run slides:compile && tsc --noEmit",
    "test": "bun run slides:compile && vitest run",
    "check": "bun run typecheck && bun run test"
  },
  "dependencies": {
    "hono-slides": "workspace:*"
  }
}
