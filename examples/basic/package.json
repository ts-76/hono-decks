{
  "name": "@hono-decks/example-basic",
  "private": true,
  "type": "module",
  "scripts": {
    "decks:compile": "hono-decks compile",
    "decks:compile:hook": "hono-decks compile",
    "dev": "CI=1 XDG_CONFIG_HOME=.wrangler-config wrangler dev --live-reload",
    "deploy": "wrangler deploy",
    "deploy:production": "wrangler deploy --config wrangler.production.jsonc",
    "smoke:pdf": "node scripts/pdf-smoke.mjs",
    "smoke:r2-cache": "node scripts/deployed-r2-cache-smoke.mjs",
    "smoke:viewport": "node scripts/viewport-smoke.mjs",
    "typecheck": "bun run decks:compile && tsc --noEmit",
    "test": "bun run decks:compile && vp test run",
    "check": "bun run typecheck && bun run test"
  },
  "dependencies": {
    "hono": "^4.12.30",
    "hono-decks": "0.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260716.1",
    "@types/node": "^26.1.1",
    "typescript": "^5.9.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.4",
    "vitest": "4.1.10",
    "wrangler": "^4.111.0"
  },
  "packageManager": "bun@1.3.13"
}
