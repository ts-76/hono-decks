{
  "name": "@hono-decks/example-ogp",
  "private": true,
  "type": "module",
  "scripts": {
    "decks:compile": "bun scripts/compile.ts",
    "decks:compile:hook": "bun scripts/compile.ts",
    "dev": "CI=1 XDG_CONFIG_HOME=.wrangler-config wrangler dev --live-reload",
    "build": "CI=1 XDG_CONFIG_HOME=.wrangler-config wrangler deploy --dry-run --outdir dist",
    "deploy": "wrangler deploy",
    "deploy:production": "wrangler deploy --config wrangler.production.jsonc",
    "typecheck": "bun run decks:compile && tsc --noEmit",
    "test": "bun run decks:compile && vp test run",
    "check": "bun run typecheck && bun run test && bun run build"
  },
  "dependencies": {
    "hono": "^4.12.30",
    "hono-decks": "0.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260716.1",
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^26.1.1",
    "satori": "^0.28.0",
    "typescript": "^5.9.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.4",
    "vite-plus": "0.2.4",
    "vitest": "4.1.10",
    "wrangler": "^4.111.0"
  },
  "packageManager": "bun@1.3.13"
}
