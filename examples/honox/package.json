{
  "name": "@hono-decks/example-honox",
  "private": true,
  "type": "module",
  "scripts": {
    "decks:compile": "hono-decks compile",
    "dev": "node ../../scripts/run-with-typescript-parser.cjs vp dev",
    "build": "node ../../scripts/run-with-typescript-parser.cjs vp build",
    "deploy": "bun run build && wrangler deploy",
    "deploy:production": "bun run build && wrangler deploy --config wrangler.production.jsonc",
    "preview": "wrangler dev",
    "typecheck": "bun run decks:compile && tsc --noEmit",
    "test": "bun run decks:compile && node ../../scripts/run-with-typescript-parser.cjs vp test run",
    "check": "bun run typecheck && bun run test && bun run build"
  },
  "dependencies": {
    "hono": "^4.12.31",
    "hono-decks": "0.1.0",
    "honox": "0.1.59"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260719.1",
    "@hono/vite-build": "^1.11.1",
    "@hono/vite-dev-server": "^0.26.1",
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.4",
    "vite-plus": "0.2.5",
    "vitest": "4.1.10",
    "wrangler": "^4.112.0"
  },
  "packageManager": "bun@1.3.13"
}
