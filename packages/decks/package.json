{
  "name": "hono-decks",
  "version": "0.1.0",
  "description": "Slide decks for Hono and Cloudflare Workers",
  "keywords": [
    "cloudflare-workers",
    "hono",
    "mdx",
    "slides"
  ],
  "homepage": "https://github.com/ts-76/hono-decks#readme",
  "bugs": {
    "url": "https://github.com/ts-76/hono-decks/issues"
  },
  "license": "MIT",
  "author": "ts-76",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ts-76/hono-decks.git",
    "directory": "packages/decks"
  },
  "bin": {
    "hono-decks": "dist/bin.js"
  },
  "files": [
    "dist",
    "README.md",
    "README.ja.md"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/mod.d.ts",
      "import": "./dist/mod.js"
    },
    "./advanced": {
      "types": "./dist/advanced.d.ts",
      "import": "./dist/advanced.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "prepack": "bun run build",
    "decks:compile": "bun run build && node dist/bin.js compile",
    "typecheck": "bun run build && tsc --noEmit && tsc --noEmit -p tsconfig.worker.json",
    "test": "bun run build && vp test run",
    "check": "bun run typecheck && bun run test"
  },
  "dependencies": {
    "@mdx-js/mdx": "^3.1.1",
    "esbuild": "^0.28.1",
    "remark-directive": "^4.0.0",
    "remark-gfm": "^4.0.0",
    "remark-mdx": "^3.1.1",
    "remark-parse": "^11.0.0",
    "shiki": "^4.3.1",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "hono": "^4.12.30",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "hono": "^4.12.30",
    "vite": "^6.0.0 || ^7.0.0 || ^8.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  }
}
